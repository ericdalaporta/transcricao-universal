# =============================================================
# Transcrição Universal — Variáveis de Ambiente
# =============================================================
# COMO USAR:
#   1. Copie este arquivo para ".env"  (mesmo nome, sem a extensão .example)
#   2. Preencha CADA valor abaixo com os dados do seu projeto Supabase
#   3. NUNCA suba o arquivo .env para o Git
# =============================================================

# --- SUPABASE ---------------------------------------------------
# Painel Supabase → Settings → API
# "Project URL"
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co

# "anon / public" (chave pública — usada pelo frontend)
SUPABASE_ANON_KEY=eyJhbGci...sua_chave_anon_aqui

# "service_role" (chave secreta — usada apenas pelo servidor, NUNCA exponha)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...sua_chave_service_role_aqui

# --- JWT --------------------------------------------------------
# Qualquer string longa e aleatória — usada para assinar os tokens de login
JWT_SECRET=troque_para_uma_string_longa_e_aleatoria_aqui

# --- MERCADO PAGO (opcional, só necessário para o Premium) ------
# Painel MP → Credenciais → Produção → Access Token
# MP_ACCESS_TOKEN=APP_USR-...

# --- GROQ (opcional — alternativa ao groq-key.txt) --------------
# GROQ_KEY=gsk_...
